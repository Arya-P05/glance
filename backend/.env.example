# Single Instagram username to scrape
INSTAGRAM_USERNAME=

# Optional (recommended for bulk): Instagram session cookie value (cookie name: sessionid)
# Without this, Instagram may limit logged-out profiles to ~12 posts.
INSTAGRAM_SESSIONID=

# If sessionid alone still caps at ~12 posts, export full instagram.com cookies as JSON and point to it:
INSTAGRAM_COOKIES_PATH=

# Supabase (use service role key so the job can write to Storage and DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Limit how many posts to fetch per run (bulk uses this too)
MAX_POSTS=50

# Set to false to watch the browser (debug)
HEADLESS=true
